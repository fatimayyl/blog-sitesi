@model IEnumerable<KurumsalWebProjesi.Models.Model.Slider>
@{ 
    Layout = null;
}
<div id="main-slider" class="flexslider">
    @foreach (var item in Model)
    {
        <ul class="slides">
           
                <li>
                    <img src="@item.ResimURL" alt="@item.Baslik" />
                    <div class="flex-caption">
                        <h3>@item.Baslik</h3>
                        <p>@item.Aciklama</p>
                        @*<a href="#" class="btn btn-theme">Devamını Oku</a>*@
                    </div>
                </li>
            

        </ul>
    }
    </div>